# zsh profileз”Ё
if [ "$ZSHRC_PROFILE" != "" ]; then
  zmodload zsh/zprof && zprof > /dev/null
fi

# === zsh.d гҒ®гғ•гӮЎгӮӨгғ«иӘӯгҒҝиҫјгҒҝ ===
ZSHD_HOME="${HOME}/.dotfiles/zsh/zsh.d"
for config_file ($ZSHD_HOME/*.zsh(N)) source $config_file

# === fzfгҒ®иЁӯе®ҡ ===
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# === extensionгҒ®гғ•гӮЎгӮӨгғ«иӘӯгҒҝиҫјгҒҝ ===
EXTENSION_HOME="${HOME}/.dotfiles/zsh/extension"
for config_file ($EXTENSION_HOME/*.zsh(N)) source $config_file

# === functionгҒ®гғ•гӮЎгӮӨгғ«иӘӯгҒҝиҫјгҒҝ ===
FUNCTION_HOME="${HOME}/.dotfiles/zsh/function"
for config_file ($FUNCTION_HOME/*.zsh(N)) source $config_file
